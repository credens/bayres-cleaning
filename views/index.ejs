                    <div class="sector-li">Áreas Hospitalarias <img src="https://cdn-icons-png.flaticon.com/512/3063/3063176.png" class="sector-icon"></div>
                    <div class="sector-li">Centros Comerciales <img src="https://cdn-icons-png.flaticon.com/512/2331/2331970.png" class="sector-icon"></div>
                    <div class="sector-li">Supermercados <img src="https://cdn-icons-png.flaticon.com/512/3759/3759500.png" class="sector-icon"></div>
                    <div class="sector-li">Countries y Barrios Cerrados <img src="https://cdn-icons-png.flaticon.com/512/2544/2544087.png" class="sector-icon"></div>
                    <div class="sector-li">Instituciones Educativas <img src="https://cdn-icons-png.flaticon.com/512/167/167707.png" class="sector-icon"></div>
                    <div class="sector-li">Finales de Obra <img src="https://cdn-icons-png.flaticon.com/512/4336/4336873.png" class="sector-icon"></div>
                    <div class="sector-li">Bancos <img src="https://cdn-icons-png.flaticon.com/512/2830/2830284.png" class="sector-icon"></div>
                </div>
            </div>
            <div class="banner-negro">
                <div class="banner-info">
                    <ul>
                        <li>Limpieza y Desinfección de superficies</li>
                        <li>Limpieza de Alfombras y Tapizados</li>
                        <li>Limpieza de Cristales</li>
                        <li>Separación de Residuos</li>
                    </ul>
                </div>
                <div class="banner-img"></div>
            </div>
