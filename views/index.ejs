    <main>
        <section id="inicio" class="hero">
            <div class="container hero-flex">
                <div class="hero-text">
                    <h1 style="font-size: 3.8rem; font-weight: 800;">BAYRES<br><span style="color: var(--azul);">CLEANING.</span></h1>
                    <p style="font-size: 1.1rem; margin-top: 20px;">Servicios de limpieza profesional a la altura de sus exigencias.</p>
